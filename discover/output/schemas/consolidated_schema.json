{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Application Portfolio Schema",
  "type": "object",
  "properties": {
    "app_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "criticality": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ]
    },
    "Application status": {
      "type": "string"
    },
    "Deployment type": {
      "type": "string"
    },
    "Operating system": {
      "type": "string"
    },
    "programming language": {
      "type": "string"
    },
    "db_engine": {
      "type": "string"
    }
  }
}