{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ApplicationRecord",
  "description": "Schema for a normalized application record from the portfolio Excel ingestion",
  "type": "object",
  "required": ["app_id", "app_name"],
  "properties": {
    "app_id": {"type": "string", "description": "Unique application identifier"},
    "app_name": {"type": "string", "description": "Human-readable application name"},
    "app_description": {"type": ["string", "null"], "description": "Application purpose / function"},
    "solution_type": {"type": ["string", "null"], "enum": ["Custom made", "COTS", "SaaS", "SAP", null]},
    "business_criticality": {"type": ["string", "null"], "enum": ["High", "Medium", "Low", null]},
    "application_status": {"type": ["string", "null"], "description": "Lifecycle status, e.g. Production, Retired"},
    "deployment_type": {"type": ["string", "null"], "enum": ["On-Premise", "Cloud", "Hybrid", "SaaS", null]},
    "data_classification": {"type": ["string", "null"]},
    "business_unit": {"type": ["string", "null"]},
    "business_capabilities": {"type": ["array", "null"], "items": {"type": "string"}},
    "user_count": {"type": ["integer", "null"]},
    "operating_system": {"type": ["string", "null"]},
    "programming_language": {"type": ["string", "null"]},
    "application_server": {"type": ["string", "null"]},
    "application_architecture": {"type": ["string", "null"]},
    "is_containerized": {"type": ["string", "null"]},
    "environment_count": {"type": ["integer", "null"]},
    "server_instances": {"type": ["array", "null"], "items": {"type": "string"}},
    "cpu_cores": {"type": ["integer", "null"]},
    "memory_gb": {"type": ["integer", "null"]},
    "ci_cd_present": {"type": ["string", "null"]},
    "api_endpoint_count": {"type": ["integer", "null"]},
    "external_interface_count": {"type": ["integer", "null"]},
    "database_engine": {"type": ["string", "null"]},
    "database_storage_gb": {"type": ["integer", "null"]},
    "database_license_required": {"type": ["string", "null"]},
    "logging_solution": {"type": ["string", "null"]},
    "monitoring_tool": {"type": ["string", "null"]},
    "additional_attributes": {"type": ["object", "null"]}
  }
}
